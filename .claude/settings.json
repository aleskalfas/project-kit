      "Bash(pwd)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(ssh-keygen:*)",
      "Bash(ssh:*)",
      "Bash(tail:*)",
      "Bash(uv:*)",
      "Edit",
      "Glob",
      "Grep",
      "MultiEdit",
      "Read",
      "Skill(adapter-author)",
      "Skill(agent-author)",
      "Skill(area-author)",
      "Skill(bundle-author)",
      "Skill(capability-author)",
      "Skill(decision-author)",
