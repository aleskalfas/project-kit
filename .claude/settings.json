{
  "agent": "project-manager",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.pkit/adapters/claude-code/permission-hook.py"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": true,
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.netrc"
      ],
      "allowWrite": [
        "~/.npm",
        "~/.cache/node",
        "~/.cache/uv"
      ]
    },
    "network": {
      "allowedHosts": [
        "api.github.com"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(.pkit/**/*.sh)",
      "Bash(GH_HOST=github.com gh:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(chmod +x:*)",
      "Bash(cp:*)",
      "Bash(cut:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mkfifo:*)",
      "Bash(mktemp:*)",
      "Bash(mv:*)",
      "Bash(pkit:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(pytest:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(ruff:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(ssh-keygen:*)",
      "Bash(ssh:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Edit",
      "Glob",
      "Grep",
      "MultiEdit",
      "Read",
      "Skill(adapter-author)",
      "Skill(agent-author)",
      "Skill(area-author)",
      "Skill(bundle-author)",
      "Skill(capability-author)",
      "Skill(decision-author)",
      "Skill(demo-recording)",
      "Skill(evidence)",
      "Skill(evidence-add)",
      "Skill(evidence-validate)",
      "Skill(migration-author)",
      "Skill(pm)",
      "Skill(schema)",
      "Skill(scratchpad-author)",
      "Skill(storyboard-author)",
      "Skill(update-config)",
      "Write"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm -R:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -fR:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}
