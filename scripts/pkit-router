#!/usr/bin/env bash
#
# pkit-router — CWD-aware selector for the `pkit` command.
#
# Routes each `pkit` invocation to the right implementation based on where you
# are, so a developer juggling multiple project-kit SOURCE checkouts plus
# several adopter projects gets the correct binary automatically:
#
#   - Inside a project-kit SOURCE checkout -> that checkout's working tree, by
#     delegating to its in-tree dispatcher (.pkit/cli/pkit, PRJ-001), which runs
#     `uv run --project <checkout>` AND keeps the deploy-skills / merge-settings
#     adapter-primitive bypass. Routing is per-CWD, so each checkout exercises
#     its own source.
#   - Anywhere else (adopter repos, or no repo) -> the pinned global release.
#
# INSTALL: `mise run pkit:router-install` copies this file to a PATH dir AHEAD
# of the pinned binary. The installed copy is a versioned SNAPSHOT: when you are
# in a source checkout it compares its baked-in ROUTER_VERSION against that
# checkout's canonical copy and nags you to reinstall ONLY when the checkout
# ships a NEWER version (never a downgrade — important when checkouts diverge).
# THIS committed file is the source of truth — bump ROUTER_VERSION on any change
# (in the same PR as any layout migration) so installed copies self-detect.
#
# Source-tree anchor: the presence of THIS file (scripts/pkit-router) at the
# repo root, and the `ROUTER_VERSION=<int>` line format. Both are stable by
# contract; a migration that relocates the anchor OR changes that line's format
# MUST instruct a reinstall, because an already-installed copy cannot
# self-detect those two specific changes. Every other change self-screams.

ROUTER_VERSION=1

set -euo pipefail

note() { printf 'pkit-router: %s\n' "$*" >&2; }

# Follow symlinks and canonicalise a path; never aborts under `set -e`.
_resolve() {
    local p="$1" t d
    while [ -L "$p" ]; do
        t="$(readlink "$p")" || break
        case "$t" in /*) p="$t" ;; *) p="$(dirname -- "$p")/$t" ;; esac
    done
    d="$(cd "$(dirname -- "$p")" 2>/dev/null && pwd -P)" || d="$(dirname -- "$p")"
    printf '%s/%s\n' "$d" "$(basename -- "$p")"
}

# Read ROUTER_VERSION from a file; prints the value or nothing. Self-terminating
# (no pipe), so it can't SIGPIPE-abort the script on the per-call hot path.
_router_version() {
    awk '/^ROUTER_VERSION=/{sub(/^ROUTER_VERSION=/,"");print $1;exit}' "$1" 2>/dev/null || true
}

self="$(command -v -- "$0" || printf '%s' "$0")"
self_rp="$(_resolve "$self")"

# Locate the enclosing repo root (git first, then a .git/.pkit walk-up — the
# same boundary the in-tree dispatcher uses).
root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$root" ]; then
    cur="$PWD"
    while [ "$cur" != "/" ]; do
        if [ -e "$cur/.git" ] || [ -d "$cur/.pkit" ]; then root="$cur"; break; fi
        cur="$(dirname -- "$cur")"
    done
fi

# --- In a project-kit SOURCE checkout -> run its working tree ----------------
if [ -n "${root:-}" ] && [ -f "$root/scripts/pkit-router" ]; then
    expected="$(_router_version "$root/scripts/pkit-router")"
    case "$expected" in
        '' | *[!0-9]*) : ;;  # unparseable -> stay quiet rather than false-alarm
        *)
            # Warn only when the checkout is NEWER; reinstalling upgrades. Never
            # nag from an older checkout (that would thrash a downgrade).
            if [ "$expected" -gt "$ROUTER_VERSION" ]; then
                note "this checkout expects router v$expected but the installed shim is v$ROUTER_VERSION. Re-run: mise run pkit:router-install"
            fi
            ;;
    esac
    dispatcher="$root/.pkit/cli/pkit"
    if [ -x "$dispatcher" ]; then
        exec "$dispatcher" "$@"
    fi
    # Source tree recognised but the dispatcher is missing / not executable ->
    # be loud rather than silently routing dev work to the pinned release.
    note "source checkout at $root but no executable .pkit/cli/pkit — layout or permissions changed. Re-run: mise run pkit:router-install"
fi

# --- Everywhere else -> the pinned release -----------------------------------
# Resolve the pinned location only here (not on the source-tree hot path). Ask
# uv for the authoritative bin dir; fall back to the env chain if uv is absent.
pinned="${PKIT_PINNED_BIN:-}"
if [ -z "$pinned" ]; then
    bindir="$(uv tool dir --bin 2>/dev/null || true)"
    [ -z "$bindir" ] && bindir="${UV_TOOL_BIN_DIR:-${XDG_BIN_HOME:-$HOME/.local/bin}}"
    pinned="$bindir/pkit"
fi
if [ ! -x "$pinned" ]; then
    note "no pinned pkit at $pinned. Run: mise run pkit:pinned-install"
    exit 127
fi
# Self-exec guard: never exec ourselves (fork-bomb protection).
if [ "$(_resolve "$pinned")" = "$self_rp" ]; then
    note "refusing to exec self ($pinned resolves to this router); the pinned install is missing or shadowed. Run: mise run pkit:pinned-install"
    exit 127
fi
exec "$pinned" "$@"
